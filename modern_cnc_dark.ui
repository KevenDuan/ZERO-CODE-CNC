  <property name="styleSheet">
   <string notr="true">
/* ==============================================
   康瑞智能化科技有限公司 - CNC - 高级深空灰主题
   ============================================== */

QWidget {
    background-color: #2B2D30;
    color: #DFE1E5; 
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 13px;
}

QWidget#widget_Sidebar {
    background-color: #1E1F22;
    border-right: 2px solid #181A1C;
}
QWidget#widget_SubNav {
    border-bottom: 2px solid #181A1C;
    padding-bottom: 12px;
}
QScrollArea#scrollArea_RightPanel {
    border: none;
    border-left: 2px solid #181A1C;
}

/* 新增下面这一段，把分割线固定在总翻页容器上 */
QStackedWidget#stackedWidget_Main {
    border-left: 2px solid #181A1C;
}
/* 将左侧分割线直接绑定给所有翻页实体，彻底解决消失问题 */
QWidget#page_Process,
QWidget#page_CNC,
QWidget#page_UserParam,
QWidget#page_SysParam,
QWidget#page_Edit,
QWidget#page_Offset,
QWidget#page_Magazine,
QWidget#page_Tool {
    border-left: 3px solid #181A1C;
}

QWidget#scrollAreaWidgetContents {
    background-color: #2B2D30;
}

QWidget#page_Process QLabel {
    background-color: #323437;
}

QLabel#lbl_Logo {
    color: #548AF7; 
    font-size: 20px;
    font-weight: bold;
}
QWidget#widget_Sidebar QPushButton {
    background-color: transparent;
    border: none;
    border-left: 4px solid transparent; 
    border-radius: 0px; 
    text-align: center;
    padding: 20px 12px; 
    font-size: 16px;
    color: #A9B0B7;
}
QWidget#widget_Sidebar QPushButton:hover {
    background-color: #2B2D30;
    color: #FFFFFF;
}
QWidget#widget_Sidebar QPushButton:checked {
    background-color: #2B2D30; 
    color: #548AF7;
    border-left: 4px solid #548AF7;
}
QWidget#widget_SubNav QPushButton {
    background-color: #393B40;
    border: 1px solid #43454A;
    border-radius: 15px;
    padding: 6px 18px;
    color: #DFE1E5;
}
QWidget#widget_SubNav QPushButton:hover {
    background-color: #4A4D53;
}
QWidget#widget_SubNav QPushButton:pressed {
    background-color: #548AF7;
    color: white;
    border-color: #548AF7;
}

QGroupBox {
    border: 1px solid #43454A;
    border-radius: 6px;
    margin-top: 15px;
    background-color: #323437;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    left: 10px;
    color: #A9B0B7;
    font-weight: bold;
}

/* 恢复明确的硬核边框 */
QWidget#widget_CAD_Viewer {
    background-color: #1E1F22;
    border: 1px solid #43454A;
    border-radius: 6px;
}

QGraphicsView#graphicsView_CAD {
    background-color: transparent;
    border: none;
}

QGroupBox#groupBox_DRO {
    background-color: #1E2328; 
    border: 1px solid #43454A;
    border-right: none; 
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 0px;
    margin-top: 0px;
    padding-top: 5px;
}
QLabel#lbl_X_Val, QLabel#lbl_Y_Val, QLabel#lbl_Z_Val,
QLabel#lbl_WX_Val, QLabel#lbl_WY_Val, QLabel#lbl_WZ_Val {
    font-family: &quot;Consolas&quot;, monospace;
    font-size: 26px;
    font-weight: bold;
    color: #6AAB73; 
    qproperty-alignment: AlignCenter;
}
QLabel#lbl_X_Title, QLabel#lbl_Y_Title, QLabel#lbl_Z_Title,
QLabel#lbl_WX_Title, QLabel#lbl_WY_Title, QLabel#lbl_WZ_Title {
    font-size: 20px;
    font-weight: bold;
    color: #548AF7;
    qproperty-alignment: AlignCenter;
}

QTextBrowser#textBrowser_Log {
    background-color: #1E1F22;
    border: 1px solid #43454A;
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    color: #A9B0B7;
    font-family: &quot;Consolas&quot;, monospace;
    padding: 10px;
}

QPushButton {
    background-color: #43454A;
    border: 1px solid #53565C;
    border-radius: 4px;
    padding: 8px 12px;
    color: #DFE1E5;
}
QPushButton:hover {
    background-color: #4E5157;
    border-color: #5E6268;
}
QPushButton:pressed {
    background-color: #393B40;
}
QPushButton#btn_Machine_Start {
    background-color: #388E3C; 
    border: 1px solid #2E7D32;
    color: #FFFFFF;
    font-weight: bold;
    font-size: 18px;
    padding: 14px 12px;
}
QPushButton#btn_Machine_Start:hover {
    background-color: #4CAF50;
}
QPushButton#btn_Machine_EStop {
    background-color: #C62828; 
    border: 1px solid #B71C1C;
    color: #FFFFFF;
    font-weight: bold;
    font-size: 16px;
}
QPushButton#btn_Machine_EStop:hover {
    background-color: #E53935;
}

QGroupBox#groupBox_Aux QPushButton {
    background-color: #2B2D30;
    border: 1px solid #43454A;
    border-radius: 4px;
    padding: 10px 4px; 
    color: #A9B0B7;
    font-weight: bold;
}
QGroupBox#groupBox_Aux QPushButton:hover {
    background-color: #393B40;
    border-color: #5E6268;
}
QGroupBox#groupBox_Aux QPushButton:checked {
    background-color: #548AF7;
    border: 1px solid #3A6ACC;
    color: #FFFFFF;
}

QLineEdit {
    background-color: #1E1F22;
    border: 1px solid #43454A;
    border-radius: 4px;
    padding: 6px 8px; 
    color: #4FC3F7;   
    font-family: &quot;Consolas&quot;, monospace;
    font-weight: bold;
    font-size: 14px;
    selection-background-color: #548AF7;
}
QLineEdit:focus {
    border: 1px solid #548AF7;
}
QSlider::groove:horizontal {
    border: 1px solid #43454A;
    height: 6px;
    background: #1E1F22;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background: #548AF7; 
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #DFE1E5;
    border: 1px solid #43454A;
    width: 14px;
    margin-top: -5px;
    margin-bottom: -5px;
    border-radius: 7px;
}
QSlider::handle:horizontal:hover {
    background: #FFFFFF;
}

/* 悬浮小加号按钮样式 (已放大优化) */
QPushButton#btn_Small_Import {
    background-color: rgba(84, 138, 247, 0.15);
    border: 2px dashed #548AF7; /* 蓝色虚线框 */
    border-radius: 20px;
    color: #548AF7;
    font-size: 12px;
    font-weight: bold;
    margin: 15px;
}
QPushButton#btn_Small_Import:hover {
    background-color: #548AF7;
    border: 2px solid #548AF7;
    color: #FFFFFF;
}

/* CNC表格全局样式补充 */
QHeaderView::section {
    background-color: #1E1F22;
    color: #A9B0B7;
    padding: 4px;
    border: 1px solid #181A1C;
}
QTableView {
    background-color: #1E1F22;
    gridline-color: #2B2D30;
    border: 1px solid #43454A;
    selection-background-color: #548AF7;
}
