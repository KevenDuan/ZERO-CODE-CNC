QSlider::groove:horizontal {
border: 1px solid #4A708B;
height:15px;
/*必须有这两句，一句也不能少，不然高度是默认高度。
groove:槽
*/
}
 
QSlider::sub-page:horizontal {
background-color: rgb(0, 255, 0);
border: 3px solid rgb(255, 85, 0);
height: 5px;
border-radius: 7px;
/*按钮左边*/
